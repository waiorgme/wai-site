---
// Self-hosted fonts (polish slice): no render-blocking third-party CSS.
// The Arabic face is imported by the /ar pages themselves so English visitors
// never download it.
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource/hanken-grotesk/400.css';
import '@fontsource/hanken-grotesk/500.css';
import '@fontsource/hanken-grotesk/600.css';
import '@fontsource/hanken-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import '../styles/tokens.css';

interface Props {
  title: string;
  description: string;
  lang?: 'en' | 'ar';
  /** Canonical path for this page, e.g. "/about". Enables canonical + og:url. */
  path?: string;
  /** The same page in the other language, e.g. "/ar/about" - emits reciprocal hreflang. */
  alternate?: string;
  /** Keep private surfaces (portal, verify) out of search results. */
  noindex?: boolean;
}

// One site constant (site.config.mjs) so canonical URLs, og:url, hreflang,
// the sitemap and astro.config's `site` all agree.
import { SITE } from '../../site.config.mjs';

const { title, description, lang = 'en', path, alternate, noindex = false } = Astro.props;
const dir = lang === 'ar' ? 'rtl' : 'ltr';
const canonical = path !== undefined ? `${SITE}${path}` : undefined;
const alternateUrl = alternate !== undefined ? `${SITE}${alternate}` : undefined;
// x-default points at the English page (the site's primary language).
const xDefault =
  path === undefined
    ? undefined
    : lang === 'en'
      ? canonical
      : alternateUrl;
const skipLabel = lang === 'ar' ? 'تخطّي إلى المحتوى' : 'Skip to content';
---

<!DOCTYPE html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#060d1c" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/icon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {canonical && <link rel="canonical" href={canonical} />}
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:locale" content={lang === 'ar' ? 'ar_AE' : 'en_US'} />
    {canonical && alternateUrl && (
      <>
        <link rel="alternate" hreflang={lang} href={canonical} />
        <link rel="alternate" hreflang={lang === 'ar' ? 'en' : 'ar'} href={alternateUrl} />
        <link rel="alternate" hreflang="x-default" href={xDefault} />
      </>
    )}

    <slot name="head" />
  </head>
  <body>
    <a class="skip" href="#main">{skipLabel}</a>
    <slot />
  </body>
</html>
