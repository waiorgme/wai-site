---
import '../styles/tokens.css';

interface Props {
  title: string;
  description: string;
  lang?: 'en' | 'ar';
}

const { title, description, lang = 'en' } = Astro.props;
const dir = lang === 'ar' ? 'rtl' : 'ltr';
---

<!DOCTYPE html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#060d1c" />
    <link rel="icon" type="image/png" href="/assets/wai-me-icon.png" />
    <link rel="apple-touch-icon" href="/assets/wai-me-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=IBM+Plex+Sans+Arabic:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <slot />
  </body>
</html>
