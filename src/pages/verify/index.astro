---
import Base from "../../layouts/Base.astro";
import { VerifyApp } from "../../portal/VerifyApp";
---

<Base
  title="Verify a certificate - Women in Aviation Middle East"
  description="Confirm a Women in Aviation Middle East certificate is genuine."
  noindex
  path="/verify/"
>
  <main id="main" class="verify">
    <noscript>
      <p class="nojs">
        Certificate verification needs JavaScript, and it looks like your
        browser has it switched off. Turn it on and reload this page, or email
        <a href="mailto:support@waiorg.me">support@waiorg.me</a> with the
        certificate ID and we will confirm it for you.
      </p>
    </noscript>
    <VerifyApp client:only="react" />
  </main>
</Base>

<style>
  .nojs {
    color: var(--mist-mut);
    max-width: 52ch;
    text-align: center;
    padding-top: 30vh;
  }
  .nojs a { color: var(--sky); }
  .verify {
    min-height: 100dvh;
    display: grid;
    place-items: start center;
    padding: var(--gutter);
    background: radial-gradient(
      1200px 600px at 50% -10%,
      var(--navy),
      var(--ink) 60%
    );
  }
  @media print {
    @page {
      size: A4 landscape;
      margin: 0;
    }
    .verify {
      background: #fff;
      padding: 0;
    }
    :global(body *) {
      visibility: hidden;
    }
    :global(.cert-print),
    :global(.cert-print *) {
      visibility: visible;
    }
    :global(.cert-print) {
      position: absolute;
      left: 0;
      top: 0;
    }
  }
</style>
