---
import Base from "../../layouts/Base.astro";
import "../../styles/panel.css";
import { VerifyApp } from "../../portal/VerifyApp";
---

<Base
  title="Verify a certificate - Women in Aviation Middle East"
  description="Confirm a Women in Aviation Middle East certificate is genuine."
  noindex
  path="/verify/"
>
  <main id="main" class="panel-scope verify-shell">
    {/* The designed field behind the card (wow-elevation D4): a quiet paper
        gradient plus a seal-adjacent ring motif in plain SVG geometry - never
        a redrawn logo. Decorative only; the print rules already hide it. */}
    <div class="vf" aria-hidden="true">
      <svg class="vf-seal" viewBox="0 0 360 360" fill="none">
        <circle cx="180" cy="180" r="168" stroke="currentColor" />
        <circle cx="180" cy="180" r="150" stroke="currentColor" stroke-dasharray="1.5 7" />
        <circle cx="180" cy="180" r="118" stroke="currentColor" />
        <circle cx="180" cy="180" r="112" stroke="currentColor" />
      </svg>
    </div>
    <div class="pn-center">
      <noscript>
        <p class="nojs">
          Certificate verification needs JavaScript, and it looks like your
          browser has it switched off. Turn it on and reload this page, or email
          <a href="mailto:support@waiorg.me">support@waiorg.me</a> with the
          certificate ID and we will confirm it for you.
        </p>
      </noscript>
      <VerifyApp client:only="react" />
    </div>
  </main>
</Base>

<style>
  /* The institutional field (D4): background-image layers only - the main's
     computed background-color stays --paper (test-pinned rgb(246,241,232)). */
  .verify-shell {
    position: relative;
    overflow: clip;
  }
  .vf {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(1100px 520px at 50% -8%, var(--paper-2), transparent 68%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.55), rgba(255, 255, 255, 0) 320px);
  }
  .vf-seal {
    position: absolute;
    inset-block-start: clamp(56px, 12vh, 140px);
    inset-inline-start: 50%;
    transform: translateX(-50%);
    inline-size: clamp(300px, 42vw, 460px);
    color: rgba(10, 29, 63, 0.07);
  }
  /* the card layer paints above the positioned field */
  .verify-shell .pn-center {
    position: relative;
  }
  @media print {
    .vf {
      display: none;
    }
  }

  /* Print only the certificate: everything on the page hides except the
     .cert-print block VerifyApp renders around the certificate. */
  @media print {
    @page {
      size: A4 landscape;
      margin: 0;
    }
    .panel-scope {
      background: #fff;
    }
    .pn-center {
      padding: 0;
    }
    :global(body *) {
      visibility: hidden;
    }
    :global(.cert-print),
    :global(.cert-print *) {
      visibility: visible;
    }
    :global(.cert-print) {
      position: absolute;
      inset-block-start: 0;
      inset-inline-start: 0;
    }
    /* The on-screen certificate is scaled to its container via an INLINE
       transform (ScaledCertificate); without these overrides a phone prints
       a third-size certificate in a sea of white. Stylesheet !important
       beats inline styles, so print always gets the full 1122x794 canvas
       (A4 landscape above). */
    :global(.cert-print > div) {
      height: auto !important;
      overflow: visible !important;
    }
    :global(.cert-print > div > div) {
      transform: none !important;
    }
  }
</style>
