---
import Base from '../layouts/Base.astro';
import '../styles/home.css';
import '../styles/legal.css';

import Nav from '../components/home/Nav.astro';
import Footer from '../components/home/Footer.astro';

// Copy is verbatim from the vault: 02 Platform/02 Membership Terms & Website
// Conditions (Draft) (Issam-approved draft 2026-07-02, LEGAL-3). The combined
// legal review before launch is a tracked owner task. The meta description is
// the draft's own unaltered opening sentence ("Who these terms are between").
const description =
  'These terms are an agreement between you and Women in Aviation Middle East (WAI-ME), a recognised chapter of Women in Aviation International, hosted by the Emirates Aerosports Federation, c/o Emirates Aerosports Federation, Skydive HQ, Dubai, United Arab Emirates.';
---

<Base
  title="Terms - Women in Aviation Middle East"
  description={description}
  path="/terms/"
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Women in Aviation Middle East" />
    <meta property="og:title" content="Membership Terms & Website Conditions" />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://www.waiorg.me/assets/share-card.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://www.waiorg.me/assets/share-card.png" />
  </Fragment>

  <span class="top-sentinel" id="topSentinel" aria-hidden="true"></span>

  <Nav />

  <main id="main">
    <span id="top"></span>

    <header class="legal-hero">
      <div class="wrap">
        <p class="eyebrow">Terms</p>
        <h1>Membership Terms &amp; Website Conditions</h1>
        {/* No lede: the vault terms draft has no summary sentence, and legal
            pages carry only verbatim vault copy (Gate 4). */}
      </div>
    </header>

    <section class="legal-body">
      <div class="wrap">
        <div class="legal-inner">
          <h2>Who these terms are between</h2>
          <p>
            These terms are an agreement between you and Women in Aviation Middle East
            (WAI-ME), a recognised chapter of Women in Aviation International, hosted by
            the Emirates Aerosports Federation, c/o Emirates Aerosports Federation,
            Skydive HQ, Dubai, United Arab Emirates. By using this website or holding a
            WAI-ME membership, you agree to them. Questions:
            <a href="mailto:support@waiorg.me">support@waiorg.me</a>.
          </p>

          <h2>Membership</h2>
          <ul>
            <li><strong>Membership is free.</strong> There is no fee to join and no fee to remain a member.</li>
            <li><strong>Who can join:</strong> anyone aged 13 or over. Members under 18 join only with a parent or guardian's consent, and their account stays in a protected setting with extra safeguards until they turn 18. How we protect young members: our <a href="/safeguarding">Safeguarding of Members Under 18</a> page.</li>
            <li><strong>Your details must be accurate.</strong> You confirm at sign-up that your details, including your age and gender, are true. If we find an account was created with false details, we may suspend or close it.</li>
            <li><strong>One account per person.</strong> Your account is personal to you and signs in through a link we email you. Keep access to your email safe; anyone who can read your email can enter your account.</li>
            <li><strong>Your choices stay yours.</strong> Marketing emails and partner searchability are separate, optional choices, off unless you turn them on, and reversible at any time. How we handle your information is set out in our <a href="/privacy">Privacy Policy</a>, which is part of these terms.</li>
          </ul>

          <h2>The house rules</h2>
          <p>WAI-ME is a professional community. By joining, you agree to:</p>
          <ul>
            <li>treat other members with respect, in person and online;</li>
            <li>follow our safeguarding rules wherever young members are involved;</li>
            <li>use member information you encounter through WAI-ME (for example at events) only for community purposes, never for unsolicited selling or recruiting outside the channels we provide;</li>
            <li>not misuse the platform: no false accounts, no attempts to access other members' data, no scraping, and no interference with how the site works.</li>
          </ul>
          <p>
            We may suspend or close an account that breaks these rules. Where we can, we
            will tell you what happened and hear you out first; where safety is
            involved, we act first and explain after.
          </p>

          <h2>Certificates</h2>
          <p>
            Certificates we issue (for example your membership certificate) remain
            WAI-ME documents. Each one carries a verification link that shows whether it
            is current. You are welcome to share your own certificate; you may not alter
            it, issue lookalikes, or present a revoked or superseded certificate as
            current.
          </p>

          <h2>Events and programmes</h2>
          <p>
            Events, workshops, scholarships, and other opportunities may carry their own
            terms (for example a partner's conditions or an event venue's rules). Where
            they do, we tell you at the point you sign up for that activity, and those
            terms apply alongside these.
          </p>

          <h2>Using this website</h2>
          <ul>
            <li><strong>Content:</strong> the material on this site belongs to WAI-ME or its licensors and is protected by copyright and trademark law. You may view and download it for personal, non-commercial use. You may not republish it, sell it, or present it as your own.</li>
            <li><strong>Accuracy:</strong> we work to keep the site accurate and current, but we do not promise it is free of errors, and we may change material at any time without notice.</li>
            <li><strong>Other sites we link to:</strong> we are not responsible for the content or practices of external sites. A link is not an endorsement.</li>
            <li><strong>Availability:</strong> we do not promise the site or member area will always be available or uninterrupted.</li>
          </ul>

          <h2>Our responsibility to you</h2>
          <p>
            We provide this website and our community programmes with care, but to the
            extent the law allows, WAI-ME is not liable for indirect losses (such as
            loss of data, profit, or opportunity) arising from your use of, or inability
            to use, this website. Nothing in these terms removes rights the law gives
            you that cannot be excluded.
          </p>

          <h2>Changes to these terms</h2>
          <p>
            If we change these terms, we update the date below and, for important
            changes, tell members directly. Continuing to use the site or your
            membership after a change means you accept the updated terms.
          </p>

          <h2>Governing law</h2>
          <p>
            These terms are governed by the laws of Dubai and the applicable federal
            laws of the United Arab Emirates, and the courts of Dubai have exclusive
            jurisdiction.
          </p>

          <p class="updated">
            Last updated: 2 July 2026 · Contact:
            <a href="mailto:support@waiorg.me">support@waiorg.me</a>
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script src="../scripts/home-motion.js"></script>
</Base>
