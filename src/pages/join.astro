---
import Base from '../layouts/Base.astro';
import '../styles/home.css';

import Nav from '../components/home/Nav.astro';
import Footer from '../components/home/Footer.astro';
import { JoinApp } from '../portal/JoinApp';
---
<Base
  title="Join - Women in Aviation Middle East"
  description="Join Women in Aviation Middle East. Membership is free and open to women at every stage of aviation."
>
  <Nav />
  <main id="main" class="join">
    <span id="top"></span>
    <section class="join-sec">
      <JoinApp client:only="react" />
    </section>
  </main>
  <Footer />
</Base>

<style>
  .join-sec{
    background:var(--ink);
    min-height:100vh;
    display:grid;
    place-items:center;
    padding-block:clamp(120px,14vw,180px) clamp(72px,10vw,130px);
    padding-inline:var(--gutter);
  }
</style>
