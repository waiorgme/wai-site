---
import Base from '../layouts/Base.astro';
import '../styles/home.css';
import '../styles/panel.css';

import Nav from '../components/home/Nav.astro';
import Footer from '../components/home/Footer.astro';
import { JoinApp } from '../portal/JoinApp';
---
<Base
  title="Join - Women in Aviation Middle East"
  description="Join Women in Aviation Middle East. Membership is free and open to women at every stage of aviation."
  path="/join/"
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Women in Aviation Middle East" />
    <meta property="og:title" content="Join Women in Aviation Middle East" />
    <meta property="og:description" content="Membership is free and open to women at every stage of aviation." />
    <meta property="og:image" content="https://www.waiorg.me/assets/share-card.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://www.waiorg.me/assets/share-card.png" />
  </Fragment>
  <Nav />
  <main id="main" class="join">
    <span id="top"></span>
    <section class="panel-scope join-sec">
      <noscript>
        <p class="nojs">
          The join form needs JavaScript, and it looks like your browser has it
          switched off. Turn it on and reload this page, or email us at
          <a href="mailto:support@waiorg.me">support@waiorg.me</a> and we will
          sign you up by hand.
        </p>
      </noscript>
      <JoinApp client:only="react" />
    </section>
  </main>
  <Footer />
</Base>

<style>
  /* A slim ink strip stays above the paper section so the fixed glass nav
     reads against dark, then the join section breaks into daylight - the
     same dark-hero-to-paper transition as membership (.mbr-who). */
  .join{
    background:var(--ink);
    padding-block-start:clamp(96px,12vw,150px);
  }
  .join-sec{
    min-height:100vh;
    display:grid;
    place-items:center;
    border-radius:40px 40px 0 0;
    padding-block:clamp(56px,8vw,96px) clamp(72px,10vw,130px);
    padding-inline:var(--gutter);
  }
  /* panel.css centers .nojs with a 30vh offset for full-page shells; this
     section is already centered between the nav band and the footer. */
  .join-sec .nojs{ padding-block-start:0; }
</style>
