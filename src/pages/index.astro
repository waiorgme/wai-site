---
import Base from '../layouts/Base.astro';
import '../styles/home.css';

import Nav from '../components/home/Nav.astro';
import Hero from '../components/home/Hero.astro';
import FlightData from '../components/home/FlightData.astro';
import StatBand from '../components/home/StatBand.astro';
import Pillars from '../components/home/Pillars.astro';
import Mission from '../components/home/Mission.astro';
import Spotlight from '../components/home/Spotlight.astro';
import EventsGrid from '../components/home/EventsGrid.astro';
import Partners from '../components/home/Partners.astro';
import JoinBand from '../components/home/JoinBand.astro';
import Footer from '../components/home/Footer.astro';
---

<Base
  title="Women in Aviation Middle East, across the region"
  description="The Middle East community for women building careers in aviation and aerospace. We open doors to training, mentors, scholarships, and each other."
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en" />
    <meta property="og:site_name" content="Women in Aviation Middle East" />
    <meta property="og:title" content="Women in aviation, across the region." />
    <meta property="og:description" content="The Middle East community for women building careers in aviation and aerospace. We open doors to training, mentors, scholarships, and each other." />
    <meta property="og:image" content="/assets/wai-me-logo-on-dark.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Women in aviation, across the region." />
    <meta name="twitter:description" content="The Middle East community for women building careers in aviation and aerospace. We open doors to training, mentors, scholarships, and each other." />
    <meta name="twitter:image" content="/assets/wai-me-logo-on-dark.png" />
  </Fragment>

  <span class="top-sentinel" id="topSentinel" aria-hidden="true"></span>

  <Nav />

  <main id="main">
    <span id="top"></span>
    <Hero />
    <FlightData />
    <StatBand />
    <Pillars />
    <Mission />
    <Spotlight />
    <EventsGrid />
    <Partners />
    <JoinBand />
  </main>

  <Footer />

  <script src="../scripts/home-motion.js"></script>
</Base>
