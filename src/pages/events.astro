---
import Base from '../layouts/Base.astro';
import '../styles/home.css';
import '../styles/events.css';

import Nav from '../components/home/Nav.astro';
import Footer from '../components/home/Footer.astro';

import EventsHero from '../components/events/EventsHero.astro';
import RecentHighlights from '../components/events/RecentHighlights.astro';
import ArchiveTimeline from '../components/events/ArchiveTimeline.astro';
import EventsArchive from '../components/events/EventsArchive.astro';
import EventsJoinBand from '../components/events/EventsJoinBand.astro';

// Meta description / og / twitter are composed ONLY of complete, unaltered sentences
// taken verbatim from this page's vault copy (the intro paragraph). No paraphrase.
const metaDescription = 'WAI-ME shows up where the industry gathers and brings members into the room. Members attend free.';
---

<Base
  path="/events/"
  alternate="/ar/events/"
  title="Events - Women in Aviation Middle East"
  description={metaDescription}
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Women in Aviation Middle East" />
    <meta property="og:title" content="What's been happening, and what's next." />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content="https://www.waiorg.me/assets/wai-me-logo-on-dark.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="What's been happening, and what's next." />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content="https://www.waiorg.me/assets/wai-me-logo-on-dark.png" />
  </Fragment>

  <span class="top-sentinel" id="topSentinel" aria-hidden="true"></span>

  <Nav />

  <main id="main">
    <span id="top"></span>
    <EventsHero />
    <RecentHighlights />
    <ArchiveTimeline />
    <EventsArchive />
    <EventsJoinBand />
  </main>

  <Footer />

  <script src="../scripts/home-motion.js"></script>
</Base>
