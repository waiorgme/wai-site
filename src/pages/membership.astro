---
import Base from '../layouts/Base.astro';
import '../styles/home.css';
import '../styles/membership.css';

import Nav from '../components/home/Nav.astro';
import Footer from '../components/home/Footer.astro';

import MembershipHero from '../components/membership/MembershipHero.astro';
import MembershipFlightData from '../components/membership/MembershipFlightData.astro';
import WhoItsFor from '../components/membership/WhoItsFor.astro';
import WhatYouGet from '../components/membership/WhatYouGet.astro';
import HowRecognitionWorks from '../components/membership/HowRecognitionWorks.astro';
import HowToJoin from '../components/membership/HowToJoin.astro';
import MembershipJoinBand from '../components/membership/MembershipJoinBand.astro';
---

<Base
  title="Membership - Women in Aviation Middle East"
  description="WAI-ME membership is free and open to women at every stage of aviation, from the student with the dream to the captain with the legacy."
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en" />
    <meta property="og:site_name" content="Women in Aviation Middle East" />
    <meta property="og:title" content="Membership is free. The only currency is showing up." />
    <meta property="og:description" content="WAI-ME membership is free and open to women at every stage of aviation, from the student with the dream to the captain with the legacy." />
    <meta property="og:image" content="/assets/wai-me-logo-on-dark.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Membership is free. The only currency is showing up." />
    <meta name="twitter:description" content="WAI-ME membership is free and open to women at every stage of aviation, from the student with the dream to the captain with the legacy." />
    <meta name="twitter:image" content="/assets/wai-me-logo-on-dark.png" />
  </Fragment>

  <span class="top-sentinel" id="topSentinel" aria-hidden="true"></span>

  <Nav />

  <main id="main">
    <span id="top"></span>
    <MembershipHero />
    <MembershipFlightData />
    <WhoItsFor />
    <WhatYouGet />
    <HowRecognitionWorks />
    <HowToJoin />
    <MembershipJoinBand />
  </main>

  <Footer />

  <script src="../scripts/home-motion.js"></script>
</Base>
