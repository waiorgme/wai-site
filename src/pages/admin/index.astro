---
import Base from "../../layouts/Base.astro";
import { AdminApp } from "../../admin/AdminApp";
import "../../styles/panel.css";
---

<Base
  title="Admin - Women in Aviation Middle East"
  description="WAI-ME admin panel."
  noindex
  path="/admin/"
>
  <main id="main" class="panel-scope">
    <noscript>
      <p class="nojs">
        The admin panel needs JavaScript, and it looks like your browser has it
        switched off. Turn it on and reload this page.
      </p>
    </noscript>
    <AdminApp client:only="react" />
  </main>
</Base>
