---
import Base from "../../layouts/Base.astro";
import { AdminApp } from "../../admin/AdminApp";
---

<Base
  title="Admin - Women in Aviation Middle East"
  description="WAI-ME admin panel."
  noindex
  path="/admin/"
>
  <main id="main" class="admin">
    <noscript>
      <p class="nojs">
        The admin panel needs JavaScript, and it looks like your browser has it
        switched off. Turn it on and reload this page.
      </p>
    </noscript>
    <AdminApp client:only="react" />
  </main>
</Base>

<style>
  .nojs {
    color: var(--mist-mut);
    max-width: 52ch;
    text-align: center;
    padding-top: 30vh;
  }
  .nojs a { color: var(--sky); }
  .admin {
    min-height: 100dvh;
    display: grid;
    place-items: start center;
    padding: var(--gutter);
    background: radial-gradient(
      1200px 600px at 50% -10%,
      var(--navy),
      var(--ink) 60%
    );
  }
</style>
