---
import Base from "../../layouts/Base.astro";
import { PortalApp } from "../../portal/PortalApp";
---

<Base
  title="Member Portal - Women in Aviation Middle East"
  description="Sign in to the WAI-ME member portal."
  noindex
  path="/portal/"
>
  <main id="main" class="portal">
    <noscript>
      <p class="nojs">
        The member portal needs JavaScript, and it looks like your browser has
        it switched off. Turn it on and reload this page, or email
        <a href="mailto:support@waiorg.me">support@waiorg.me</a> for help
        signing in.
      </p>
    </noscript>
    <PortalApp client:only="react" />
  </main>
</Base>

<style>
  .nojs {
    color: var(--mist-mut);
    max-width: 52ch;
    text-align: center;
    padding-top: 30vh;
  }
  .nojs a { color: var(--sky); }
  .portal {
    min-height: 100dvh;
    display: grid;
    place-items: start center;
    padding: var(--gutter);
    background: radial-gradient(
      1200px 600px at 50% -10%,
      var(--navy),
      var(--ink) 60%
    );
  }
</style>
