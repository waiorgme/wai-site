---
import Base from "../../layouts/Base.astro";
import { PortalApp } from "../../portal/PortalApp";
import "../../styles/panel.css";
---

<Base
  title="Member Portal - Women in Aviation Middle East"
  description="Sign in to the WAI-ME member portal."
  noindex
  path="/portal/"
>
  <main id="main" class="panel-scope">
    <noscript>
      <p class="nojs">
        The member portal needs JavaScript, and it looks like your browser has
        it switched off. Turn it on and reload this page, or email
        <a href="mailto:support@waiorg.me">support@waiorg.me</a> for help
        signing in.
      </p>
    </noscript>
    <PortalApp client:only="react" />
  </main>
</Base>
