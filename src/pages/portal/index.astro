---
import Base from "../../layouts/Base.astro";
import { PortalApp } from "../../portal/PortalApp";
---

<Base
  title="Member Portal — WAI-ME"
  description="Sign in to the WAI-ME member portal."
>
  <link
    slot="head"
    href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
  <main id="main" class="portal">
    <PortalApp client:only="react" />
  </main>
</Base>

<style>
  .portal {
    min-height: 100dvh;
    display: grid;
    place-items: start center;
    padding: var(--gutter);
    background: radial-gradient(
      1200px 600px at 50% -10%,
      var(--navy),
      var(--ink) 60%
    );
  }
</style>
