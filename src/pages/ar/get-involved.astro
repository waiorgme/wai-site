---
import Base from '../../layouts/Base.astro';
import '../../styles/home.css';
import '../../styles/involved.css';
import '../../styles/ar.css';

import Nav from '../../components/ar/Nav.astro';
import Footer from '../../components/ar/Footer.astro';

import InvolvedHero from '../../components/ar/InvolvedHero.astro';
import WhyPartner from '../../components/ar/WhyPartner.astro';
import HowToJoin from '../../components/ar/HowToJoin.astro';

const metaDescription = 'ادعم المرأة التي ستُدير طيران المنطقة. المرأة في الطيران – الشرق الأوسط لا تتلقّى أي مبالغ.';
---

<Base
  path="/ar/get-involved/"
  alternate="/get-involved/"
  lang="ar"
  title="شارك معنا - المرأة في الطيران – الشرق الأوسط"
  description={metaDescription}
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="المرأة في الطيران – الشرق الأوسط" />
  </Fragment>

  <span class="top-sentinel" id="topSentinel" aria-hidden="true"></span>

  <Nav />

  <main id="main">
    <span id="top"></span>
    <InvolvedHero />
    <WhyPartner />
    <HowToJoin />
  </main>

  <Footer />

  <script src="../../scripts/home-motion.js"></script>
</Base>
