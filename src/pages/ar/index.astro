---
import Base from '../../layouts/Base.astro';
import '../../styles/home.css';
import '../../styles/ar.css';

import Nav from '../../components/ar/Nav.astro';
import Hero from '../../components/ar/Hero.astro';
import Pillars from '../../components/ar/Pillars.astro';
import Mission from '../../components/ar/Mission.astro';
import Partners from '../../components/ar/Partners.astro';
import JoinBand from '../../components/ar/JoinBand.astro';
import Footer from '../../components/ar/Footer.astro';
---

<Base
  path="/ar/"
  alternate="/"
  lang="ar"
  title="المرأة في الطيران – الشرق الأوسط، في أنحاء المنطقة"
  description="مجتمع الشرق الأوسط للمرأة التي تبني مسيرتها في الطيران والفضاء الجوي. نفتح الأبواب إلى التدريب والإرشاد والمنح الدراسية."
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="المرأة في الطيران – الشرق الأوسط" />
    <meta property="og:image" content="https://www.waiorg.me/assets/wai-me-logo-on-dark.png" />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'Women in Aviation Middle East',
        alternateName: 'WAI-ME',
        url: 'https://www.waiorg.me/ar/',
        logo: 'https://www.waiorg.me/assets/wai-me-logo-on-dark.png',
        email: 'support@waiorg.me',
        sameAs: [
          'https://facebook.com/womeninaviation.me',
          'https://instagram.com/womeninaviation.me',
          'https://twitter.com/waiorgme',
          'https://linkedin.com/company/women-in-aviation-middle-east',
          'https://youtube.com/channel/UC4_uDB08aGlQ1LkWfGuG22Q',
        ],
        parentOrganization: {
          '@type': 'Organization',
          name: 'Women in Aviation International',
          url: 'https://www.wai.org/',
        },
      })}
    />
  </Fragment>

  <span class="top-sentinel" id="topSentinel" aria-hidden="true"></span>

  <Nav />

  <main id="main">
    <span id="top"></span>
    <Hero />
    <Pillars />
    <Mission />
    <Partners />
    <JoinBand />
  </main>

  <Footer />

  <script src="../../scripts/home-motion.js"></script>
</Base>
