---
import Base from '../layouts/Base.astro';
import '../styles/home.css';
import '../styles/legal.css';

import Nav from '../components/home/Nav.astro';
import Footer from '../components/home/Footer.astro';
---

<Base
  title="Page not found - Women in Aviation Middle East"
  description="That page doesn't exist. Head back to the Women in Aviation Middle East home page."
  path="/404/"
  noindex
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Women in Aviation Middle East" />
    <meta property="og:title" content="Page not found" />
    <meta
      property="og:image"
      content="https://www.waiorg.me/assets/share-card.png"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:image"
      content="https://www.waiorg.me/assets/share-card.png"
    />
  </Fragment>

  <span class="top-sentinel" id="topSentinel" aria-hidden="true"></span>

  <Nav />

  <main id="main">
    <div class="notfound">
      <p class="code">404</p>
      <h1>Off the flight path</h1>
      <p>
        That page doesn't exist, or it may have moved. Let's get you back on
        course.
      </p>
      <p class="ar-line" lang="ar">هذه الصفحة غير موجودة. عودي إلى الصفحة الرئيسية.</p>
      <div class="links">
        <a href="/">Home</a>
        <a href="/join">Join WAI-ME</a>
        <a href="/contact">Contact</a>
        <a href="/ar/" lang="ar">الصفحة الرئيسية بالعربية</a>
      </div>
    </div>
  </main>

  <Footer />
</Base>
