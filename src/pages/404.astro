---
import Base from '../layouts/Base.astro';
import '../styles/home.css';
import '../styles/legal.css';

import Nav from '../components/home/Nav.astro';
import Footer from '../components/home/Footer.astro';
---

<Base
  title="Page not found - Women in Aviation Middle East"
  description="That page doesn't exist. Head back to the Women in Aviation Middle East home page."
  path="/404/"
  noindex
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Women in Aviation Middle East" />
    <meta property="og:title" content="Page not found" />
    <meta
      property="og:image"
      content="https://www.waiorg.me/assets/share-card.png"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:image"
      content="https://www.waiorg.me/assets/share-card.png"
    />
  </Fragment>

  <span class="top-sentinel" id="topSentinel" aria-hidden="true"></span>

  <Nav />

  <main id="main">
    <div class="notfound">
      {/* The diverted flight path (wow-elevation C7): climbs, kinks off course,
          then recovers. Decorative only; .flightline/.draw come from home.css and
          home-motion.js draws it in (reduced motion renders it fully drawn). */}
      <svg class="nf-route" viewBox="0 0 1440 620" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <path class="flightline draw" d="M-40 520 C 240 484, 440 420, 620 330 S 860 216, 940 258 C 1020 300, 1120 210, 1230 128 S 1420 16, 1500 -12" pathLength="1" stroke-opacity="0.5"/>
      </svg>
      <p class="code">404</p>
      <h1>Off the flight path</h1>
      <p>
        That page doesn't exist, or it may have moved. Let's get you back on
        course.
      </p>
      <p class="ar-line" lang="ar">هذه الصفحة غير موجودة. عودي إلى الصفحة الرئيسية.</p>
      <div class="links">
        <a class="btn" href="/">Home</a>
        <a class="btn ghost" href="/join">Join WAI-ME</a>
        <a class="btn ghost" href="/contact">Contact</a>
        <a class="btn ghost" href="/ar/" lang="ar">الصفحة الرئيسية بالعربية</a>
      </div>
    </div>
  </main>

  <Footer />

  <script src="../scripts/home-motion.js"></script>
</Base>

<style>
  /* wow-elevation C7, local to this page (legal.css and home.css stay untouched):
     anchor the diverted route behind the hero copy and let the recovery links
     wear the shared pill button language from home.css. */
  .notfound{ position:relative; overflow:hidden; isolation:isolate; }
  .nf-route{
    position:absolute; inset:0; inline-size:100%; block-size:100%;
    z-index:-1; pointer-events:none; opacity:.55;
  }
  /* undo the legal.css underlined-link treatment on the pills; the arrow-less
     pill keeps symmetric padding */
  .notfound .links{ gap:14px; }
  .notfound .links a.btn{ text-decoration:none; color:var(--fg); padding-inline:24px; }
</style>
