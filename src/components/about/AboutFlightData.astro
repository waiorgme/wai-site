---
// Flight-data strip (instrument readout) for the About page. Count-up numbers carry
// sr-only fallbacks so no-JS / reduced-motion users always read the final figures.
// Figures (2013, 1,300+, 40+, 750+) are the locked About stat set.
---
<section class="flightdata" aria-label="WAI-ME at a glance">
  <div class="wrap">
    <div class="fd-panel fd-4 reveal">
      <div class="fd-cell">
        <div class="label">Since</div>
        <div class="val">2013</div>
        <div class="sub">building the chapter across the Middle East</div>
      </div>
      <div class="fd-cell">
        <div class="label">Community</div>
        <div class="val"><span class="count" data-to="1300" data-format="comma" aria-hidden="true">1,300</span><span class="sr-only">1,300</span>+ members</div>
        <div class="sub">across the Middle East and beyond</div>
      </div>
      <div class="fd-cell">
        <div class="label">Reach</div>
        <div class="val"><span class="count" data-to="40" aria-hidden="true">40</span><span class="sr-only">40</span>+ countries</div>
        <div class="sub">where our members live and work</div>
      </div>
      <div class="fd-cell">
        <div class="label">Conference 2019</div>
        <div class="val"><span class="count" data-to="750" aria-hidden="true">750</span><span class="sr-only">750</span>+ attendees</div>
        <div class="sub">a cornerstone regional event for women in aviation</div>
      </div>
    </div>
  </div>
</section>
