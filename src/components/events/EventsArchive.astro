---
import Eyebrow from '../primitives/Eyebrow.astro';
import events from '../../data/events-archive.json';

// Full events archive: all 32 real events server-rendered (SEO-complete, works with
// JS disabled). Filter + "Show more" pagination are progressive enhancement layered on
// in events-archive.js, gated behind the `.js` class. Real photos, so NO concept marker.
// Locks: NO gold anywhere; category tags + active filter use brand SKY only; every dash
// is a regular hyphen; copy verbatim (framing from the vault note, names/excerpts from JSON).

// Verbatim framing copy (vault: 04 Events Archive - Public Listing).
const filters = ['All', 'Conference', 'Exhibition', 'Networking', 'Convention', 'Meeting'];

// Per-category counts for the filter chips.
const counts: Record<string, number> = { All: events.length };
for (const f of filters.slice(1)) counts[f] = events.filter((e) => e.category === f).length;

const PAGE_SIZE = 9;
---
<section class="ev-archive-full" aria-labelledby="archive-full-h">
  <div class="wrap">
    <div class="head reveal">
      <Eyebrow>The full archive</Eyebrow>
      <h2 id="archive-full-h">Twelve years in the room.</h2>
      <p class="intro">
        <span class="lead-stat">32</span> events across the region and beyond, from
        <span class="lead-num">2013</span> to <span class="lead-num">2024</span>. Filter by type,
        or keep scrolling through the history.
      </p>
    </div>

    <div
      class="ev-filters reveal"
      role="group"
      aria-label="Filter events by type"
      data-events-filters
      style="--i:1"
    >
      {filters.map((f, i) => (
        <button
          type="button"
          class="ev-filter"
          data-filter={f}
          aria-pressed={i === 0 ? 'true' : 'false'}
        >
          <span class="ev-filter-label">{f}</span>
          <span class="ev-filter-count" aria-hidden="true">{counts[f]}</span>
        </button>
      ))}
    </div>

    <p class="ev-empty" data-events-empty hidden>No events in this category yet.</p>

    <ul class="ev-arch-grid" data-events-grid data-page-size={PAGE_SIZE}>
      {events.map((e, i) => (
        <li
          class="ev-arch-card reveal"
          data-category={e.category}
          data-index={i}
          style={`--i:${i % 3}`}
        >
          <article>
            <div class="ev-arch-ph">
              <img
                src={e.img}
                alt={e.name}
                loading="lazy"
                decoding="async"
                width="640"
                height="420"
              />
            </div>
            <div class="ev-arch-body">
              <div class="ev-arch-meta">
                <span class="ev-arch-when">{e.month} {e.year}</span>
                <span class="ev-arch-tag">{e.category}</span>
              </div>
              <h3 class="ev-arch-name">{e.name}</h3>
              <p class="ev-arch-excerpt">{e.excerpt}</p>
            </div>
          </article>
        </li>
      ))}
    </ul>

    <div class="ev-more-row" data-events-more-row hidden>
      <button type="button" class="ev-more" data-events-more>
        <span>Show more events</span>
        <span class="ev-more-count" data-events-remaining aria-hidden="true"></span>
      </button>
    </div>
  </div>
</section>

<script>
  import '../../scripts/events-archive.js';
</script>
