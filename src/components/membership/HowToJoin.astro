---
import Eyebrow from '../primitives/Eyebrow.astro';
import Button from '../primitives/Button.astro';

// How to join: three-step sequence on the dark surface. This page carries NO form
// fields; the form lives at the /join stub. Steps and closing line are verbatim.
// The returning-member block was removed per the Codex audit (its copy is marked
// [CONFIRM] in the vault, pending the claim-your-account flow + consent steps).
const steps = [
  'Tell us a little about you and where you are in aviation.',
  'Get straight into the opportunities board and the next event.',
  'Complete your profile when you are ready, the more complete it is, the more we can match you to.',
];
---
<section class="mbr-join-how" id="how-to-join" aria-labelledby="how-h">
  <div class="wrap">
    <div class="head reveal">
      <Eyebrow>How to join</Eyebrow>
      <h2 id="how-h">Joining takes a minute.</h2>
    </div>

    <ol class="steps">
      {steps.map((s, i) => (
        <li class="step-card reveal" style={`--i:${i}`}>
          <span class="step-n" aria-hidden="true">{i + 1}</span>
          <p>{s}</p>
        </li>
      ))}
    </ol>

    <p class="closing reveal" style="--i:3">There is no approval queue and no fee. You are in as soon as you join.</p>

    {/* Returning-member block ("Already a member from before?" + claim-your-profile
        body) is held back until the vault confirms copy that aligns with the
        claim-your-account flow + consent steps. Restore here once confirmed.
        (Astro comment: stripped at build, never ships in HTML.) */}

    <div class="cta-row reveal" style="--i:4">
      <Button href="/join" magnetic>Become a member</Button>
    </div>
  </div>
</section>
