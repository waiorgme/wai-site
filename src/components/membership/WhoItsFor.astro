---
import Eyebrow from '../primitives/Eyebrow.astro';

// Who it's for: four audience descriptions on paper. Per the vault build note
// (02 Public Website Content - English (Draft), "Who it's for") and
// [[wai-plain-language-ux-rule]], the lead-words "Dreamer / Entrant" and
// "standing" are INTERNAL and must not surface to members. So each card renders
// ONLY the verbatim description sentence, with no lead-word and no invented
// heading. Plain prose cards, no tier table, no threshold numbers.
// Each card carries one decorative persona roundel (Lucide outline glyphs, 1.5px
// stroke, currentColor - same aesthetic as the panel's icons.tsx): graduation cap
// for the students, compass for the women finding their way in, plane for the
// women already flying the industry, award for the visible few.
const audiences = [
  {
    text: 'Students, cadets, and schoolgirls with the dream. You get a way in, scholarships and training leads, and your ambition taken seriously.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 10v6"/><path d="M2 10 12 5l10 5-10 5z"/><path d="M6 12.5V17c3 2.5 9 2.5 12 0v-4.5"/></svg>',
  },
  {
    text: 'Women breaking into aviation, or returning after another field or a career break. You get contacts, doors, and help turning the skills you have into an aviation role.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>',
  },
  {
    text: 'Women already working in the industry, junior to senior. You get a peer network, a route to your next rating or role, and a way to give back.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>',
  },
  {
    text: 'Captains, managers, founders, and the visible few. You get a platform, recognition, and the chance to open doors you once needed opened for you.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>',
  },
];
---
<section class="mbr-who" id="who" aria-labelledby="who-h">
  <div class="wrap">
    <div class="head reveal">
      <Eyebrow onPaper>Who it's for</Eyebrow>
      <h2 id="who-h">Who it's for</h2>
    </div>
    <p class="intro reveal" style="--i:1">Membership is open to women at any stage of the aviation journey:</p>

    <div class="who-grid">
      {audiences.map((a, i) => (
        <article class="who-card reveal" style={`--i:${i % 2}`}>
          <span class="roundel" aria-hidden="true" set:html={a.icon} />
          <p>{a.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
