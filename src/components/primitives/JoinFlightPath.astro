---
// The hero's flight path returns for the final ascent in every join band.
// Decorative only (aria-hidden); draws in on reveal via the shared .draw
// primitive, and ar.css mirrors .flight-svg for RTL reading.
---
<svg class="flight-svg" viewBox="0 0 1440 640" preserveAspectRatio="xMidYMax slice" aria-hidden="true">
  <path class="flightline draw" d="M-40 580 C 320 540, 660 430, 920 300 S 1330 110, 1510 40" pathLength="1" stroke-opacity="0.4"/>
</svg>
