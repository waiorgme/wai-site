---
import Eyebrow from '../primitives/Eyebrow.astro';
import Photo from '../primitives/Photo.astro';

// Member spotlight kept in its placeholder "Awaiting a real member" staging state.
---
<section class="spotlight" id="spotlight" aria-labelledby="spot-h">
  <div class="wrap">
    <div class="grid">
      <div class="text reveal">
        <Eyebrow onPaper>Member spotlight</Eyebrow>
        <h2 id="spot-h">Meet the women shaping the region's skies.</h2>
        <div class="slot">
          <span class="awaiting">Awaiting a real member, with her own words</span>
          {/* decorative climb route: the seat is reserved, the path is drawn */}
          <svg class="slot-route" viewBox="0 0 360 84" aria-hidden="true">
            <circle class="pt" cx="8" cy="74" r="3.5" fill-opacity=".9"/>
            <path class="flightline draw" d="M8 74 C 96 70, 168 50, 224 36 S 330 12, 352 9" pathLength="1" stroke-opacity=".5"/>
            <circle class="pt" cx="352" cy="9" r="3.5" fill-opacity=".9"/>
          </svg>
        </div>
      </div>
      <div class="portrait reveal" style="--i:1">
        {/* REAL photograph from the 2025 General Assembly (Riyadh): a panelist
            mid-session. Atmosphere for the reserved spotlight seat, not a
            claimed identity - she is unnamed until a featured member is chosen. */}
        <Photo
          src="/assets/photos/assembly-portrait.webp"
          alt="A young panelist holding a microphone during a session at the 2025 Women in Aviation General Assembly in Riyadh."
          scrim
          mark="2025 General Assembly, Riyadh"
        />
      </div>
    </div>
  </div>
</section>
