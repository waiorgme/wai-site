---
import Button from '../primitives/Button.astro';
import LangToggle from '../primitives/LangToggle.astro';

// Floating glass-pill nav + full-screen mobile menu (focus-trapped via home-motion.js).
// Real logo asset only: /assets/wai-me-logo-on-dark.png. Canonical site nav (matches the
// footer route set in the vault content draft): About, Membership, Get Involved, Events, Contact.
// Active page gets aria-current + a gliding pill indicator (design-system Tabs "pill" variant,
// wired in home-motion.js). The indicator rests behind the current page and glides on hover.
const links = [
  { href: '/about', label: 'About' },
  { href: '/membership', label: 'Membership' },
  { href: '/get-involved', label: 'Get Involved' },
  { href: '/events', label: 'Events' },
  { href: '/contact', label: 'Contact' },
];
const path = (Astro.url.pathname.replace(/\/+$/, '') || '/');
const isActive = (href: string) => href.startsWith('/') && path === href.replace(/\/+$/, '');
---
<header class="site">
  <nav class="nav" aria-label="Primary">
    <a class="brand" href="/" aria-label="Women in Aviation Middle East, home">
      <img src="/assets/wai-me-logo-on-dark.png" alt="Women in Aviation Middle East" />
    </a>
    <div class="links">
      <span class="nav-ind" aria-hidden="true"></span>
      {links.map((l) => (
        <a href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>{l.label}</a>
      ))}
    </div>
    <LangToggle lang="en" />
    <div class="cta-d">
      <Button href="/membership" magnetic>Become a member</Button>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

<div class="mobile-menu" id="mobileMenu" role="dialog" aria-modal="true" aria-label="Site menu">
  <a class="m-link" href="/about">About</a>
  <a class="m-link" href="/membership">Membership</a>
  <a class="m-link" href="/get-involved">Get Involved</a>
  <a class="m-link" href="/events">Events</a>
  <a class="m-link" href="/contact">Contact</a>
  <div class="m-cta">
    <Button href="/membership">Become a member</Button>
  </div>
</div>
