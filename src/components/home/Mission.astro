---
import Eyebrow from '../primitives/Eyebrow.astro';
import ConceptMark from '../primitives/ConceptMark.astro';
---
<section class="mission" id="mission" aria-labelledby="mission-h">
  <div class="bg par-slow">
    <img data-src="https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=2000&q=80&auto=format&fit=crop"
         alt="Concept image: a wide dawn sky above a calm horizon, the light a career begins in. Placeholder, real WAI-ME imagery will replace it." />
    <div class="grad" aria-hidden="true"></div>
  </div>
  <ConceptMark corner text="Concept image, real WAI-ME photo to follow" />
  <div class="wrap">
    <Eyebrow class="reveal">Our mission</Eyebrow>
    <blockquote>
      <p class="q reveal" id="mission-h" style="--i:1">Making a difference, one person at a time. We move women from <span class="hl">outside, dreaming</span>, to <span class="hl">inside, leading</span>, and every woman who rises turns around to lift the one behind her.</p>
      <cite class="reveal" style="--i:2">Women in Aviation Middle East</cite>
    </blockquote>
  </div>
</section>
