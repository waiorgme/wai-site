---
import Eyebrow from '../primitives/Eyebrow.astro';
import Button from '../primitives/Button.astro';
import ConceptMark from '../primitives/ConceptMark.astro';
---
<section class="hero" aria-labelledby="hero-h">
  <div class="hero-photo par-slow">
    {/* LCP element: loads eagerly with high priority (PERF-1); the onload
        class swap keeps the same fade-in the design system expects.
        REAL photograph: WAI-ME speakers and guests on stage at the chapter's
        Airport Show conference, supplied directly by Issam for the hero
        (2026-07-13); original filed in the vault (04 Events/_Inbox - To
        File/TOM00657.jpg). Publication clearance sits with Mervat (staging
        preview). */}
    <img src="/assets/photos/hero-stage-group.webp"
         alt="Speakers and guests of Women in Aviation Middle East standing together on the conference stage beneath the Women in Aviation banner."
         loading="eager"
         fetchpriority="high"
         decoding="async"
         onload="this.classList.add('loaded')" />
  </div>
  <div class="veil" aria-hidden="true"></div>
  <div class="dawn" aria-hidden="true"></div>
  <div class="glow-orb a" aria-hidden="true"></div>
  <svg class="flight-svg" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <path class="flightline draw" d="M-40 760 C 360 720, 620 560, 880 380 S 1280 120, 1520 40" pathLength="1" stroke-opacity="0.55"/>
    <circle r="4" fill="#6cc8ff"><animateMotion dur="0" /></circle>
  </svg>

  <div class="inner">
    <Eyebrow class="over reveal">Women in Aviation Middle East <span class="tick"></span> A chapter of Women in Aviation International</Eyebrow>
    <h1 id="hero-h" aria-label="Women in aviation, across the region.">
      <span class="line-mask"><span>Women in aviation,</span></span>
      <span class="line-mask"><span class="accent">across the region.</span></span>
    </h1>
    <p class="lede reveal" style="--i:2">We are the Middle East community for women building careers in aviation and aerospace. Students, pilots, engineers, cabin crew, air-traffic and airport professionals, and the leaders who came before them. We open doors to training, mentors, scholarships, and each other.</p>
    <div class="cta-row reveal" style="--i:3">
      <Button href="/join" magnetic>Become a member</Button>
      <Button href="/about" ghost>Read our story</Button>
    </div>
    <div class="scroll-hint reveal" style="--i:4" aria-hidden="true">
      <span>Begin the climb</span>
    </div>
  </div>
</section>
