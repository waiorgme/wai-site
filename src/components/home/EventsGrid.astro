---
import Eyebrow from '../primitives/Eyebrow.astro';
import Photo from '../primitives/Photo.astro';
---
<section class="events" id="events" aria-labelledby="ev-h">
  <div class="wrap">
    <div class="head reveal">
      <div>
        <Eyebrow>Recent highlights</Eyebrow>
        <h2 id="ev-h">Where we've been.</h2>
      </div>
      <p class="intro">Members attend WAI-ME events free. Many are open to everyone.</p>
    </div>

    <div class="ev-grid">
      {/* whole cards link to the events page: they always looked tappable (B2);
          the year chip is gone because every title already starts with it */}
      <a class="ev-card reveal" href="/events">
        <div class="ph">
          <Photo
            src="/assets/photos/audience-depth-900.webp"
            alt="A full WAI-ME conference room, rows of members receding into the hall."
            scrim
            mark="Archive photo, 2017 Airport Show"
          />
        </div>
        <div class="body">
          <div class="tags"><span class="chip free">Members free</span></div>
          <h3>2025 Dubai Airshow</h3>
          <p>One of the region's defining gatherings, where WAI-ME brings members into the room.</p>
        </div>
      </a>

      <a class="ev-card reveal" style="--i:1" href="/events">
        <div class="ph">
          <Photo
            src="/assets/photos/assembly-panel-900.webp"
            alt="Panelists standing together on stage at the Women in Aviation General Assembly."
            scrim
            mark="2025 General Assembly"
          />
        </div>
        <div class="body">
          <div class="tags"><span class="chip free">Members free</span></div>
          <h3>2025 Riyadh General Assembly</h3>
          <p>Where a scholarship initiative worth more than USD 150,000 included a full ATPL.</p>
        </div>
      </a>

      <a class="ev-card reveal" style="--i:2" href="/events">
        <div class="ph">
          <Photo
            src="/assets/events/2024_Annual_Conference_Dubai.webp"
            alt="The 2024 WAI-ME Annual Conference and Awards in Dubai."
            scrim
          />
        </div>
        <div class="body">
          <div class="tags"><span class="chip free">Members free</span></div>
          <h3>2024 Annual Conference and Awards</h3>
          <p>Co-located with the Airport Show in Dubai, under the patronage of His Highness Sheikh Ahmed bin Saeed Al Maktoum.</p>
        </div>
      </a>
    </div>
    <p class="more reveal"><b>More dates coming.</b> Join to hear first.</p>
  </div>
</section>
