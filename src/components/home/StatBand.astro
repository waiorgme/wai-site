---
import Eyebrow from '../primitives/Eyebrow.astro';

// Outcomes stat band. The feature card (funded ATPL / Rahaf Kaddoura) is the
// recognition moment, the only gold card in this section.
---
<section class="outcomes" id="impact" aria-labelledby="out-h">
  <div class="glow-orb" aria-hidden="true"></div>
  <div class="wrap">
    <div class="head reveal">
      <Eyebrow>The proof, not the pitch</Eyebrow>
      <h2 id="out-h">Real outcomes, on the record.</h2>
    </div>
    <div class="out-grid">

      <article class="out-card feature reveal">
        {/* REAL photograph of the stage where this award was made: the 2025
            General Assembly, Riyadh. Masked into the card base per the
            .photo-mini treatment. */}
        <div class="photo-mini" aria-hidden="true">
          <img data-src="/assets/photos/assembly-certificates-900.webp" alt="" />
        </div>
        <div class="award-ring" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg></div>
        <div class="k">Recognition</div>
        <div>
          <div class="num">A full ATPL,<br>funded</div>
          <div class="name">Rahaf Kaddoura</div>
          <p class="cap">A complete commercial pilot licence, awarded at the Riyadh General Assembly in December 2025, through a scholarship initiative worth more than USD 150,000.</p>
        </div>
      </article>

      <article class="out-card reveal" style="--i:1">
        <div class="k">Community</div>
        <div class="num"><span class="count" data-to="1300" data-format="comma" aria-hidden="true">1,300</span><span class="sr-only">1,300</span>+</div>
        <p class="cap">members across more than 40 countries, most in their twenties and thirties, the generation entering the industry now.</p>
      </article>

      <article class="out-card reveal" style="--i:2">
        <div class="k">2019 conference</div>
        <div class="num"><span class="count" data-to="750" aria-hidden="true">750</span><span class="sr-only">750</span>+</div>
        <p class="cap">attendees with 26 international speakers, under the patronage of His Highness Sheikh Ahmed bin Saeed Al Maktoum.</p>
      </article>

      <article class="out-card reveal" style="--i:3">
        <div class="k">On the calendar</div>
        <div class="num"><span class="count" data-to="12" aria-hidden="true">12</span><span class="sr-only">12</span>+ yrs</div>
        <p class="cap">present at the region's major aviation events every year since 2013, from Dubai and Abu Dhabi to Kuwait and Riyadh.</p>
      </article>

      <article class="out-card reveal" style="--i:4">
        <div class="k">Speakers, 2019</div>
        <div class="num"><span class="count" data-to="26" aria-hidden="true">26</span><span class="sr-only">26</span></div>
        <p class="cap">international speakers shared the stage at our cornerstone regional conference.</p>
      </article>

    </div>
  </div>
</section>
