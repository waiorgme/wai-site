---
import Button from '../primitives/Button.astro';
import JoinFlightPath from '../primitives/JoinFlightPath.astro';
---
<section class="join" id="join" aria-labelledby="join-h">
  <div class="dawn" aria-hidden="true"></div>
  <div class="glow-orb" aria-hidden="true"></div>
  <JoinFlightPath />
  <div class="wrap">
    <div class="inner">
      <h2 id="join-h" class="reveal">If you love aviation, <span class="accent">you belong here.</span></h2>
      <p class="reveal" style="--i:1">Membership is free, and it is open to women at any stage, from the student with the dream to the captain with the legacy. Companies that want to back the next generation can join as corporate partners.</p>
      <div class="cta-row reveal" style="--i:2">
        <Button href="/membership" magnetic>Become a member</Button>
        <Button href="/get-involved" ghost>Support as a partner</Button>
      </div>
    </div>
  </div>
</section>
