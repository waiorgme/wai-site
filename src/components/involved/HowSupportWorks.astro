---
import Eyebrow from '../primitives/Eyebrow.astro';

// How the support works: single verbatim paragraph on paper (S3). Rendered as the
// page's quiet "statement" beat, same display-weight prose as the recognition
// explainer on Membership. WAI-ME handles no cash, so no money framing is added.
---
<section class="inv-how-works" id="how-support-works" aria-labelledby="hsw-h">
  <div class="wrap">
    <div class="head reveal">
      <Eyebrow onPaper>How the support works</Eyebrow>
      <h2 id="hsw-h">How the support works</h2>
    </div>
    <p class="hsw-body reveal" style="--i:1">WAI-ME handles no cash. A partner commits a set amount of support each year and delivers it directly, by funding a scholarship or training, running a workshop, offering internships, or paying a WAI-ME cost straight to the supplier. Every dirham goes to the beneficiary, the student, the trainer, the venue, with nothing held in between. It is a cleaner story than pooling donations, and it is the model we are proud of.</p>
  </div>
</section>
