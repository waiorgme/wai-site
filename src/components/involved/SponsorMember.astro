---
import Eyebrow from '../primitives/Eyebrow.astro';

// Sponsor a member (S7): a quiet closing note on the dark surface, verbatim.
// OPEN ITEM: the dedicated contact route for this sub-option is NOT confirmed,
// so no separate email/form/route is invented here. The page already exposes the
// existing support@waiorg.me path via the "How to join" band directly above, so
// this section adds no extra CTA (per the spec's open-item directive).
---
<section class="inv-sponsor" id="sponsor-a-member" aria-labelledby="sponsor-h">
  <div class="wrap">
    <div class="inner">
      <Eyebrow class="reveal">Sponsor a member</Eyebrow>
      <h2 id="sponsor-h" class="reveal" style="--i:1">Sponsor a member</h2>
      <p class="reveal" style="--i:2">Individuals and companies can also fund a single member's training or scholarship directly.</p>
    </div>
  </div>
</section>
