---
<section class="ct-channels">
  <div class="wrap">
    <div class="ct-email reveal">
      <span class="label">البريد الإلكتروني</span>
      <a class="addr" href="mailto:support@waiorg.me" dir="ltr">support@waiorg.me</a>
    </div>

    <nav class="ct-socials reveal" style="--i:1" aria-label="قنوات التواصل الاجتماعي للمرأة في الطيران – الشرق الأوسط">
      {socials.map((s) => (
        <a class="ct-social" href={s.href} target="_blank" rel="noopener noreferrer">
          <span class="ic" set:html={s.svg}></span>
          <span class="name" dir="ltr">{s.name}</span>
        </a>
      ))}
    </nav>
  </div>
</section>
