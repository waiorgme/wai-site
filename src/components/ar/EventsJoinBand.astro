---
import Button from '../primitives/Button.astro';
import JoinFlightPath from '../primitives/JoinFlightPath.astro';

// Events Join CTA band. Primary CTA -> English /join form.
---
<section class="join" id="join" aria-labelledby="join-h">
  <div class="dawn" aria-hidden="true"></div>
  <div class="glow-orb" aria-hidden="true"></div>
  <JoinFlightPath />
  <div class="wrap">
    <div class="inner">
      <h2 id="join-h" class="reveal">مواعيد أخرى في الطريق. انضمّي إلى المرأة في الطيران – الشرق الأوسط لتكوني أوّل من يعلم.</h2>
      <div class="cta-row reveal" style="--i:1">
        <Button href="/join" magnetic>انضمّي إلينا</Button>
      </div>
      <p class="crossover-note reveal" style="--i:2">تتواصل صفحة التسجيل بالإنجليزية، لغة العمل في الطيران، وجزءٌ من الثقة التي نساعدكِ على بنائها.</p>
    </div>
  </div>
</section>
