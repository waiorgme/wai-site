---
import Eyebrow from '../primitives/Eyebrow.astro';
import Button from '../primitives/Button.astro';
import EmailChip from '../primitives/EmailChip.astro';

// Get Involved hero: dark "climb" opener. Aimed at partners/companies, so neutral
// institutional Arabic. Email is the only path (mailto CTA, no form).
---
<section class="inv-hero" aria-labelledby="inv-h">
  <div class="dawn" aria-hidden="true"></div>
  <div class="glow-orb a" aria-hidden="true"></div>
  <svg class="flight-svg" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <path class="flightline draw" d="M-40 760 C 360 720, 620 560, 880 380 S 1280 120, 1520 40" pathLength="1" stroke-opacity="0.55"/>
  </svg>

  <div class="inner">
    <Eyebrow class="over reveal">// شارك معنا</Eyebrow>
    <h1 id="inv-h">
      <span class="line-mask"><span>ادعم المرأة</span></span>
      <span class="line-mask"><span>التي ستُدير</span></span>
      <span class="line-mask"><span class="accent">طيران المنطقة.</span></span>
    </h1>

    <div class="cta-row reveal" style="--i:3">
      <Button href="mailto:support@waiorg.me" magnetic>تحدّث إلينا حول الشراكة</Button>
      <EmailChip copyLabel="نسخ" copiedLabel="تم النسخ ✓" />
    </div>
  </div>
</section>
