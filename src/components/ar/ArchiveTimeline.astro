---
// Archive timeline: "الحكاية حتى الآن". Six year-grouped entries. Figures stay Latin.
const entries = [
  { year: '2013', text: 'أول مشاركة في معرض مطار دبي (مايو)، وأول اجتماعٍ لمجلس الإدارة الذي أسّس الفرع (أكتوبر)، ومعرض دبي للطيران (نوفمبر).' },
  { year: '2014', text: 'معرض أبوظبي للطيران، والقمة العالمية للطيران والفضاء الجوي، والمؤتمر الدولي للمرأة في الطيران في فلوريدا، وأول حضورٍ في ميبا (MEBAA).' },
  { year: '2015 إلى 2016', text: 'أول جمعيةٍ عمومية سنوية في معرض مطار دبي، ومنتدى قادة المطارات العالمي، ومعرض ويتيكس (WETEX)، وغداء IAWA في القمة العالمية للفضاء الجوي.' },
  { year: '2017 إلى 2019', text: 'نما المؤتمر عاماً بعد عام، حتى بلغ الجمعية العمومية الرابعة في 2019 بأكثر من 750 حاضرة، و26 متحدثاً دولياً، و12 راعياً.' },
  { year: '2020 إلى 2022', text: 'المؤتمر الأول لكل عامين في الكويت، ومؤتمراتٌ مدمجة خلال الجائحة، وأكثر من 400 حاضرة في معرض أبوظبي للطيران في 2022.' },
  { year: '2023 إلى 2024', text: 'المؤتمر في معرض المطارات بدبي، وأول ملتقى للمرأة في الطيران في الرياض انسجاماً مع رؤية السعودية 2030، والمؤتمر والجوائز السنوية لعام 2024.' },
];
---
<section class="ev-archive" aria-labelledby="archive-h">
  <div class="wrap">
    <div class="head reveal">
      <h2 id="archive-h">الحكاية حتى الآن</h2>
      <p class="span">2013 إلى 2024</p>
    </div>

    <ol class="timeline">
      {entries.map((e, i) => (
        <li class="tl-item reveal" style={`--i:${i}`}>
          <div class="tl-year">{e.year}</div>
          <p class="tl-text">{e.text}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
