---
import Eyebrow from '../primitives/Eyebrow.astro';
import Button from '../primitives/Button.astro';

// How to join: three-step sequence. No form fields here; the form lives at the English /join.
const steps = [
  'أخبرينا قليلاً عنكِ وعن موضعكِ في الطيران.',
  'ادخلي مباشرةً إلى لوحة الفرص والفعالية القادمة.',
  'أكملي ملفّكِ حين تكونين مستعدّة، وكلّما اكتمل أكثر، زاد ما يمكننا أن نوائمكِ معه.',
];
---
<section class="mbr-join-how" id="how-to-join" aria-labelledby="how-h">
  <div class="wrap">
    <div class="head reveal">
      <Eyebrow>كيف تنضمّين</Eyebrow>
      <h2 id="how-h">الانضمام يستغرق دقيقة.</h2>
    </div>

    <ol class="steps">
      {steps.map((s, i) => (
        <li class="step-card reveal" style={`--i:${i}`}>
          <span class="step-n" aria-hidden="true">{i + 1}</span>
          <p>{s}</p>
        </li>
      ))}
    </ol>

    <p class="closing reveal" style="--i:3">لا قائمة انتظارٍ للموافقة ولا رسوم. تصبحين عضوة بمجرّد انضمامكِ.</p>

    <div class="cta-row reveal" style="--i:4">
      <Button href="/join" magnetic>انضمّي إلينا</Button>
    </div>
  </div>
</section>
