---
import Eyebrow from '../primitives/Eyebrow.astro';
import Button from '../primitives/Button.astro';
import ConceptMark from '../primitives/ConceptMark.astro';
---
<section class="hero" aria-labelledby="hero-h">
  <div class="hero-photo par-slow">
    <img src="https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=2000&q=80&auto=format&fit=crop"
         loading="eager" fetchpriority="high" decoding="async" onload="this.classList.add('loaded')"
         alt="صورة تعبيرية: طائرة ركاب تصعد فوق بحرٍ من الغيوم نحو سماء الفجر. صورة مؤقتة، ستحلّ محلّها صورة فعلية لعضوة من المرأة في الطيران – الشرق الأوسط." />
  </div>
  <div class="veil" aria-hidden="true"></div>
  <div class="dawn" aria-hidden="true"></div>
  <div class="glow-orb a" aria-hidden="true"></div>
  <ConceptMark corner text="صورة تعبيرية، صورة عضوة فعلية لاحقاً" />
  <svg class="flight-svg" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <path class="flightline draw" d="M-40 760 C 360 720, 620 560, 880 380 S 1280 120, 1520 40" pathLength="1" stroke-opacity="0.55"/>
    <circle r="4" fill="#6cc8ff"><animateMotion dur="0" /></circle>
  </svg>

  <div class="inner">
    <Eyebrow class="over reveal">المرأة في الطيران – الشرق الأوسط <span class="tick"></span> فرعٌ من المرأة في الطيران الدولية</Eyebrow>
    <h1 id="hero-h" aria-label="المرأة في الطيران، في أنحاء المنطقة.">
      <span class="line-mask"><span>المرأة في الطيران،</span></span>
      <span class="line-mask"><span class="accent">في أنحاء المنطقة.</span></span>
    </h1>
    <p class="lede reveal" style="--i:2">نحن مجتمع الشرق الأوسط للمرأة التي تَبني مسيرتها المهنية في الطيران والفضاء الجوي، طالبةً كانت أو طيّارة أو مهندسة أو من أطقم الضيافة الجوية، أو مختصّةً في الحركة الجوية والمطارات، أو قياديّةً سبقت غيرها. نفتح الأبواب إلى التدريب والإرشاد والمنح الدراسية، وإلى بعضنا بعضاً.</p>
    <div class="cta-row reveal" style="--i:3">
      <Button href="/membership" magnetic>انضمّي إلينا</Button>
      <Button href="/ar/about" ghost>اقرئي قصّتنا</Button>
    </div>
    <div class="scroll-hint reveal" style="--i:4" aria-hidden="true">
      <span>ابدئي الصعود</span>
    </div>
  </div>
</section>
