---
import Button from '../primitives/Button.astro';

// Membership-page join band. Primary CTA -> English /join form; secondary -> /ar/get-involved.
---
<section class="join" id="join" aria-labelledby="join-h">
  <div class="dawn" aria-hidden="true"></div>
  <div class="glow-orb" aria-hidden="true"></div>
  <div class="wrap">
    <div class="inner">
      <h2 id="join-h" class="reveal">إن كنتِ تعشقين الطيران، <span class="accent">فمكانكِ هنا.</span></h2>
      <p class="reveal" style="--i:1">العضوية مجّانية، وهي مفتوحة للمرأة في كلّ مرحلة، من الطالبة صاحبة الحلم إلى الكابتن صاحبة الإرث. وبإمكان الشركات الراغبة في دعم الجيل القادم أن تنضمّ كشريكٍ مؤسسي.</p>
      <div class="cta-row reveal" style="--i:2">
        <Button href="/join" magnetic>انضمّي إلينا</Button>
        <Button href="/ar/get-involved" ghost>ادعمينا كشريك</Button>
      </div>
    </div>
  </div>
</section>
