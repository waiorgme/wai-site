---
import Eyebrow from '../primitives/Eyebrow.astro';

// Why partner with WAI-ME: two paragraphs on paper.
const paras = [
  'الشركة التي تُشارِك WAI-ME تحصل على دليلٍ موثوق من جهةٍ مستقلّة على دعمها للمرأة في الطيران، صادرٍ عن فرعٍ لهيئةٍ معترفٍ بها دولياً، لا عن تسويقها الذاتي. وتنال وصولاً مبكراً إلى قاعدةٍ متنامية من المواهب الإقليمية. كما تحصل على قصة أثرٍ سنوية يمكنها عرضها على مجلس إدارتها وموظفيها والجمهور.',
  'المرأة في الطيران – الشرق الأوسط هي فرع الشرق الأوسط من المرأة في الطيران الدولية، وتعمل منذ عام 2013 بالتعاون مع اتحاد الإمارات للرياضات الجوية. فالشركة لا تدعم مجموعةً محليةً مجهولة، بل تُشارِك الذراع الإقليمية لاسمٍ عالمي، بما يتّسق مع أولويات دولة الإمارات في تمكين المرأة والكوادر الوطنية.',
];
---
<section class="inv-why" id="why" aria-labelledby="why-h">
  <div class="wrap">
    <div class="head reveal">
      <Eyebrow onPaper>لماذا الشراكة مع WAI-ME</Eyebrow>
      <h2 id="why-h">لماذا الشراكة مع WAI-ME</h2>
    </div>
    <div class="why-body">
      {paras.map((p, i) => (
        <p class="reveal" style={`--i:${i + 1}`}>{p}</p>
      ))}
    </div>
  </div>
</section>
