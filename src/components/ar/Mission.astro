---
import Eyebrow from '../primitives/Eyebrow.astro';
import ConceptMark from '../primitives/ConceptMark.astro';
---
<section class="mission" id="mission" aria-labelledby="mission-h">
  <div class="bg par-slow">
    <img data-src="https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=2000&q=80&auto=format&fit=crop"
         alt="صورة تعبيرية: سماء فجرٍ واسعة فوق أفقٍ هادئ، النور الذي تبدأ فيه المسيرة المهنية. صورة مؤقتة، ستحلّ محلّها صورة فعلية." />
    <div class="grad" aria-hidden="true"></div>
  </div>
  <ConceptMark corner text="صورة تعبيرية، صورة فعلية لاحقاً" />
  <div class="wrap">
    <Eyebrow class="reveal">رسالتنا</Eyebrow>
    <blockquote>
      <p class="q reveal" id="mission-h" style="--i:1">نُحدِث فرقاً، شخصاً واحداً في كلّ مرة. ننقل المرأة من <span class="hl">الخارج حيث الحلم</span>، إلى <span class="hl">الداخل حيث القيادة</span>، وكلّ امرأةٍ تَرتقي تَلتفت لترفع مَن خلفها.</p>
      <cite class="reveal" style="--i:2">المرأة في الطيران – الشرق الأوسط</cite>
    </blockquote>
  </div>
</section>
