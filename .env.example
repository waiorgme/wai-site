# wai-site member portal — environment variable NAMES only (no secrets here).
# Secrets are held only by Issam (Stage 0 §2). `.env.local` is git-ignored.

# --- Convex (DB + backend) ---
# Dev deploy key, scoped to the EU West (Ireland) dev deployment. Generate with:
#   npx convex deployment token create dev --save-env
# This is what lets the CLI push/run the dev deployment non-interactively.
CONVEX_DEPLOY_KEY=
# Written automatically by `npx convex dev`.
CONVEX_URL=
CONVEX_SITE_URL=

# --- Resend (magic-link + transactional email; US — transactional only) ---
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="WAI-ME <noreply@waiorg.me>"

# --- Cloudflare Turnstile (server-side bot check on the Join form) ---
TURNSTILE_SECRET_KEY=
