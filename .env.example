# wai-site member portal — environment variable NAMES only (no secrets here).
# Secrets are held only by Issam (Stage 0 §2). `.env.local` is git-ignored.

# --- Convex (DB + backend) ---
# Dev deploy key, scoped to the EU West (Ireland) dev deployment. Generate with:
#   npx convex deployment token create dev --save-env
# This is what lets the CLI push/run the dev deployment non-interactively.
CONVEX_DEPLOY_KEY=
# Written automatically by `npx convex dev`.
CONVEX_URL=
CONVEX_SITE_URL=
# Exposed to the browser (Astro PUBLIC_ prefix) for the Convex client.
PUBLIC_CONVEX_URL=

# SITE_URL, JWT_PRIVATE_KEY and JWKS are set ON THE DEPLOYMENT (not here) by:
#   npx @convex-dev/auth --web-server-url <frontend-url>

# --- Resend (magic-link + transactional email; verified domain updates.waiorg.me) ---
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="WAI-ME <noreply@updates.waiorg.me>"

# --- Cloudflare Turnstile (bot check on the Join form) ---
# Public sitekey (browser, Astro PUBLIC_ prefix). Dev uses the always-pass test
# key 1x00000000000000000000AA; swap for the real sitekey in production.
PUBLIC_TURNSTILE_SITEKEY=
# Secret key is set ON THE DEPLOYMENT (npx convex env set TURNSTILE_SECRET_KEY ...).
# Dev uses the always-pass test secret 1x0000000000000000000000000000000AA.
TURNSTILE_SECRET_KEY=

# --- Admin panel (super-admin allowlist for /admin) ---
# The two super admins (Mervat + Issam) are identified server-side by comparing
# the signed-in member's lower-cased email against this comma-separated allowlist.
# Set ON THE DEPLOYMENT, never committed here, never client-supplied:
#   npx convex env set SUPER_ADMIN_EMAILS "mervat@example.com,issam@example.com"
# Deny-by-default: unset or empty means NO ONE is admin (Stage 0 §3). The value
# is set independently on each deployment (dev/staging/production); setting it on
# staging does not imply or authorize a production cutover.
SUPER_ADMIN_EMAILS=
